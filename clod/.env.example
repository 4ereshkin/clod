# PostgreSQL Application Database
PGAPP_DB_NAME=app_db
PGAPP_DB_USER=user
PGAPP_DB_PASSWORD=password
PGAPP_DB_VOLUME=./postgres_app_data

# PostgreSQL Temporal Database
PGT_DB_NAME=temporal
PGT_DB_USER=user
PGT_DB_PASSWORD=password
PGT_DB_VOLUME=./postgres_temporal_data

# Temporal
TMP_DEFAULT_NAMESPACE=default

# Minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DATA_PATH=./minio_data

# Portainer
PD_DATA_PATH=./portainer_data
