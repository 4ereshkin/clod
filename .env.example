WORKFLOW_VERSION=MVP-plus
SCHEMA_VERSION=1.5.0

# PostgreSQL App Database
PGAPP_DB_NAME=app_db
PGAPP_DB_USER=app_user
PGAPP_DB_PASSWORD=app_password
PGAPP_DB_HOST=127.0.0.1
PGAPP_DB_VOLUME=./data/postgres_app
PGAPP_DB_PORT=5433

# PostgreSQL Temporal Database
PGT_DB_NAME=temporal
PGT_DB_USER=temporal
PGT_DB_PASSWORD=temporal_password
PGT_DB_VOLUME=./data/postgres_temporal
PGT_DB_PORT=5434

# Temporal
TMP_DEFAULT_NAMESPACE=default
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=18233
TEMPORAL_DSN=localhost:7233

# S3 Storage (SeaweedFS)
S3_ENDPOINT=http://127.0.0.1:8333
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin
S3_BUCKET=lidar-data
S3_REGION=us-east-1

# RabbitMQ
RABBIT_DSN=amqp://guest:guest@localhost:5672/

# KeyDB / Redis
KEYDB_DSN=redis://localhost:6379

# Events
EVENT_TRANSPORT=rabbit
SIGNALR_HUB_URL=http://localhost:5000/ingestHub

# SeaweedFS
SEAWEED_MASTER_PORT=9333
SEAWEED_VOLUME_PORT=8080
SEAWEED_FILER_PORT=8888
SEAWEED_S3_PORT=8333
SEAWEED_DATA_PATH=./data/seaweedfs

# Portainer
PD_DATA_PATH=./data/portainer
PORTAINER_PORT=9443

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional - можно добавить в .env при необходимости
# DATABASE_URL=postgresql://${PGAPP_DB_USER}:${PGAPP_DB_PASSWORD}@localhost:${PGAPP_DB_PORT}/${PGAPP_DB_NAME}
